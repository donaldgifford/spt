{
  "title": "spt — Worker pools",
  "uid": "spt-worker-pools",
  "tags": [
    "spt"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "In-flight tasks (per pool)",
      "type": "timeseries",
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pool) (spt_worker_pool_inflight)",
          "legendFormat": "{{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Queue depth (per pool)",
      "type": "timeseries",
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pool) (spt_worker_pool_queue_depth)",
          "legendFormat": "{{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Task duration p95",
      "type": "timeseries",
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pool) (rate(spt_worker_task_duration_seconds_bucket[5m])))",
          "legendFormat": "{{ pool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ]
}
