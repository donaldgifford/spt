{
  "title": "spt — eBay quota",
  "uid": "spt-ebay-quota",
  "tags": [
    "spt"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "API calls (rate)",
      "type": "timeseries",
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(spt_ebay_api_calls_total[5m]))",
          "legendFormat": "calls/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Quota remaining",
      "type": "stat",
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "spt_ebay_quota_remaining",
          "legendFormat": "remaining",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "title": "Quota exhausted",
      "type": "stat",
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "spt_ebay_quota_exhausted",
          "legendFormat": "exhausted",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    }
  ]
}
